from machine import Pin, I2C
from time import sleep
from lcd_i2c import I2cLcd
---------------- LCD ----------------

i2c = I2C(0, scl=Pin(22), sda=Pin(21), freq=400000)
lcd = I2cLcd(0x27, 2, 16)
---------------- CALAVERA ----------------

calavera = [
0b01110,
0b10101,
0b11011,
0b11111,
0b01110,
0b01110,
0b10101,
0b00000
]

lcd.custom_char(0, calavera)
---------------- TECLADO MATRICIAL ----------------

teclas = [
['1', '2', '3', 'A'],
['4', '5', '6', 'B'],
['7', '8', '9', 'C'],
['*', '0', '#', 'D']
]
FILAS

filas = [
Pin(19, Pin.OUT),
Pin(18, Pin.OUT),
Pin(5, Pin.OUT),
Pin(17, Pin.OUT)
]
COLUMNAS

columnas = [
Pin(16, Pin.IN, Pin.PULL_DOWN),
Pin(4, Pin.IN, Pin.PULL_DOWN),
Pin(2, Pin.IN, Pin.PULL_DOWN),
Pin(15, Pin.IN, Pin.PULL_DOWN)
]
---------------- POSICION ----------------

x = 0
y = 0
---------------- FUNCION LEER TECLA ----------------

def leer_tecla():

for fila in filas:
    fila.value(0)

for f in range(4):

    filas[f].value(1)

    for c in range(4):

        if columnas[c].value() == 1:

            tecla = teclas[f][c]

            while columnas[c].value() == 1:
                pass

            sleep(0.2)

            return tecla

    filas[f].value(0)

return None

---------------- MOSTRAR CALAVERA ----------------

lcd.clear()
lcd.move_to(x, y)
lcd.putchar(chr(0))
---------------- BUCLE PRINCIPAL ----------------

while True:

tecla = leer_tecla()

if tecla:

    # ARRIBA
    if tecla == '2':
        if y > 0:
            y -= 1

    # ABAJO
    elif tecla == '8':
        if y < 1:
            y += 1

    # IZQUIERDA
    elif tecla == '4':
        if x > 0:
            x -= 1

    # DERECHA
    elif tecla == '6':
        if x < 15:
            x += 1

    # ACTUALIZAR PANTALLA
    lcd.clear()
    lcd.move_to(x, y)
    lcd.putchar(chr(0))
